    <script>
        function addToCalendar() {
            const event = {
                title: 'Свадьба Андрея и Юли',
                description: 'Ждем вас на нашем празднике!',
                location: 'Ижевск, ул. Орджоникидзе, 33',
                startTime: '20260605T164000',
                endTime: '20260605T235900'
            };
            const icsData = [
                'BEGIN:VCALENDAR','VERSION:2.0','PRODID:-//WeddingInvite//RU','BEGIN:VEVENT',
                `DTSTART:${event.startTime}`,`DTEND:${event.endTime}`,`SUMMARY:${event.title}`,
                `DESCRIPTION:${event.description}`,`LOCATION:${event.location}`,
                'END:VEVENT','END:VCALENDAR'
            ].join('\n');
            const blob = new Blob([icsData], { type: 'text/calendar;charset=utf-8' });
            const link = document.createElement('a');
            link.href = window.URL.createObjectURL(blob);
            link.setAttribute('download', 'wedding_date.ics');
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
        }

        window.addEventListener('load', () => {
            const path = document.getElementById('animated-path');
            const section = document.getElementById('location-section');
            
            document.querySelectorAll('.sticker img').forEach(img => {
                if (img.complete) {
                    img.classList.add('loaded');
                } else {
                    img.addEventListener('load', () => img.classList.add('loaded'));
                }
            });

            if (path && section) {
                const pathLength = path.getTotalLength();
                path.style.strokeDasharray = pathLength;
                path.style.strokeDashoffset = pathLength;

                function handleScroll() {
                    const rect = section.getBoundingClientRect();
                    const viewHeight = window.innerHeight;
                    
                    let progress = (viewHeight - rect.top) / (viewHeight + rect.height * 0.5);
                    progress = Math.max(0, Math.min(1, progress));
                    
                    path.style.strokeDashoffset = pathLength * (1 - progress);
                }

                window.addEventListener('scroll', handleScroll, { passive: true });
                handleScroll();
            }
        });
    </script>
